PORT=3000
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=newRealm
PLATFORM_DB_URL=postgresql://platform_admin:platform_pass@platform-db:5432/platform_permissions
CORS_ORIGIN=http://localhost:5173

# Intent classifier (set intent to "auto" on /api/ai/request to classify from message text)
INTENT_CLASSIFIER_URL=http://localhost:3010
INTENT_CLASSIFIER_TIMEOUT_SECONDS=0.35
INTENT_CLASSIFIER_ENABLED=true
INTENT_CLASSIFIER_SHADOW=false
INTENT_AUTO_TOKEN=auto
INTENT_TAXONOMY_PATH=
