3324775,"updated_at":1773396018,"config":{"origins":["null","http://localhost:8081"],"preflight_continue":false,"max_age":3600,"private_network":false,"credentials":true,"exposed_headers":null,"methods":["GET","HEAD","PUT","PATCH","POST","DELETE","OPTIONS","TRACE","CONNECT"],"headers":["Authorization","Content-Type"]},"enabled":true,"tags":null},{"service":{"id":"32da6fdb-bf6d-4f2b-bef5-5aba7c24f2c6"},"consumer":null,"protocols":["grpc","grpcs","http","https"],"id":"fe257f2e-526c-40ab-8212-619734682a4c","route":null,"name":"jwt","instance_name":null,"created_at":1770668990,"updated_at":1770668990,"config":{"key_claim_name":"iss","claims_to_verify":["exp"],"maximum_expiration":0,"realm":null,"uri_param_names":["jwt"],"cookie_names":[],"secret_is_base64":false,"header_names":["authorization"],"run_on_preflight":true,"anonymous":null},"enabled":true,"tags":null},{"service":null,"consumer":null,"protocols":["grpc","grpcs","http","https"],"id":"ff186530-2afb-4863-ba66-6d4cad81f9e7","route":null,"name":"pre-function","instance_name":null,"created_at":1770668990,"updated_at":1770668990,"config":{"header_filter":[],"body_filter":[],"certificate":[],"rewrite":[],"access":["local cjson = require \"cjson\"\nlocal function decode_base64(data)\n  local b = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'\n  data = string.gsub(data, '[^' .. b .. '=]', '')\n  return (data:gsub('.', function(x)\n    if (x == '=') then return '' end\n    local r, f = '', (b:find(x) - 1)\n    for i = 6, 1, -1 do r = r .. (f % 2 ^ i - f % 2 ^ (i - 1) > 0 and '1' or '0') end\n    return r;\n  end):gsub('%d%d%d%d%d%d%d%d', function(x)\n    local c = 0\n    for i = 1, 8 do c = c + (x:sub(i, i) == '1' and 2 ^ (8 - i) or 0) end\n    return string.char(c)\n  end))\nend\n\nlocal path = kong.request.get_path()\nlocal required_roles = nil\n\nif string.find(path, \"/api/admin\") then\n  required_roles = { \"admin\" }\nelseif string.find(path, \"/api/documents\") or string.find(path, \"/hello\") then\n  required_roles = { \"user\", \"admin\" }\nend\n\nif required_roles then\n  local auth_header = kong.request.get_header(\"Authorization\")\n  if not auth_header then\n    return kong.response.exit(401, { message = \"Unauthorized: No token provided\" })\n  end\n\n  local token = auth_header:gsub(\"Bearer \", \"\")\n  local _, payload_b64 = token:match(\"([^.]+).([^.]+).([^.]+)\")\n\n  if not payload_b64 then\n    return kong.response.exit(401, { message = \"Unauthorized: Invalid token format\" })\n  end\n\n  while #payload_b64 % 4 ~= 0 do payload_b64 = payload_b64 .. \"=\" end\n  payload_b64 = payload_b64:gsub(\"-\", \"+\"):gsub(\"_\", \"/\")\n\n  local ok, payload_json = pcall(decode_base64, payload_b64)\n  if not ok then\n    return kong.response.exit(401, { message = \"Unauthorized: Failed to decode token\" })\n  end\n\n  payload_json = payload_json:match(\"^%s*(.-)%s*$\")\n  payload_json = payload_json:match(\"(.*})\")\n\n  local ok, claims = pcall(cjson.decode, payload_json)\n  if not ok then\n    return kong.response.exit(401, { message = \"Unauthorized: Failed to parse token JSON\" })\n  end\n\n  if not claims.realm_access or not claims.realm_access.roles then\n    return kong.response.exit(403, { message = \"Forbidden: No roles found in token\" })\n  end\n\n  local roles = claims.realm_access.roles\n  local has_required_role = false\n  for _, r in ipairs(roles) do\n    for _, req in ipairs(required_roles) do\n      if r == req then has_required_role = true; break end\n    end\n    if has_required_role then break end\n  end\n\n  if not has_required_role then\n    return kong.response.exit(403, { message = \"Forbidden: Insufficient roles\" })\n  end\nend\n"],"log":[]},"enabled":true,"tags":null}],"next":null}
