      "id": 3,
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT api_id, COUNT(*)::bigint AS requests, SUM(CASE WHEN status >= 400 THEN 1 ELSE 0 END)::bigint AS errors, AVG(response_latency_ms)::numeric(10,1) AS avg_ms, SUM(data_processed_bytes)::bigint AS bytes FROM api_usage_records WHERE $__timeFilter(request_time) AND COALESCE(consumer_username, consumer_id) = '$consumer_username' GROUP BY api_id ORDER BY requests DESC LIMIT 10"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] },
