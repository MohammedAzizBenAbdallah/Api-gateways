          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(request_time, '1h'), 'bytes' AS metric, COALESCE(SUM(data_processed_bytes),0)::bigint AS value FROM api_usage_records WHERE $__timeFilter(request_time) AND COALESCE(consumer_username, consumer_id) = '$consumer_username' GROUP BY 1 ORDER BY 1"
